// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  "restore_on_startup": "launchpad",
  "cli_default_open_behavior": "existing_window",
  "collaboration_panel": {
    "dock": "left"
  },
  "git_panel": {
    "dock": "left"
  },
  "buffer_font_size": 14.0,
  "format_on_save": "on",
  "context_servers": {},
  "buffer_font_features": {
    "calt": false // Disable ligatures
  },
  "tab_size": 4,
  "indent_guides": {
    "active_line_width": 1,
    "coloring": "fixed",
    "background_coloring": "disabled",
    "line_width": 1
  },
  "agent_servers": {
    "codex-acp": {
      "default_config_options": {
        "mode": "auto"
      },
      "type": "registry"
    }
  },
  "toolbar": {
    "code_actions": false,
    "agent_review": true,
    "selections_menu": true,
    "quick_actions": false,
    "breadcrumbs": false
  },
  "minimap": {
    "show": "never"
  },
  "gutter": {
    "line_numbers": true
  },
  "which_key": {
    "enabled": false
  },
  "outline_panel": {
    "dock": "left",
    "button": true
  },
  "cursor_shape": "bar",
  "scrollbar": {
    "show": "auto",
    "git_diff": true
  },
  "edit_predictions": {
    "provider": "zed",
    "mode": "subtle"
  },
  "lsp": {
    "vtsls": {
      "settings": {
        "typescript": {
          "updateImportsOnFileMove": {
            "enabled": "always"
          }
        },
        "javascript": {
          "updateImportsOnFileMove": {
            "enabled": "always"
          }
        }
      },
      "enable_lsp_tasks": true
    }
  },
  "language_models": {
    "openai_compatible": {}
  },
  "ssh_connections": [
    {
      "host": "100.115.189.19",
      "username": "adelic",
      "args": [],
      "projects": []
    },
    {
      "host": "100.124.155.112",
      "args": [],
      "projects": [
        {
          "paths": ["/home/adelic/homelab/./"]
        }
      ]
    }
  ],
  "agent": {
    "commit_message_model": {
      "provider": "openrouter",
      "model": "openai/gpt-oss-20b:deepinfra"
    },
    "sidebar_side": "right",
    "dock": "right",
    "default_profile": "write",
    "tool_permissions": {
      "default": "allow"
    },
    "default_model": {
      "enable_thinking": true,
      "provider": "openrouter",
      "model": "moonshotai/kimi-k2.6"
    },
    "favorite_models": [],
    "model_parameters": []
  },
  "show_edit_predictions": false,
  "relative_line_numbers": "disabled",
  "agent_buffer_font_size": 14.0,
  "agent_ui_font_size": 14.5,
  "cursor_blink": false,
  "ui_font_family": "Maple Mono",
  "buffer_line_height": "standard",
  "project_panel": {
    "sort_mode": "directories_first",
    "hide_hidden": false,
    "scrollbar": {
      "show": "system"
    },
    "bold_folder_labels": false,
    "indent_size": 20.0,
    "git_status": true,
    "entry_spacing": "standard",
    "dock": "left"
  },
  "base_keymap": "VSCode",
  "helix_mode": false,
  "vim_mode": true,
  "terminal": {
    "dock": "bottom",
    "font_family": "JetBrainsMono Nerd Font Mono"
  },
  "autosave": "on_focus_change",
  "buffer_font_family": "Maple Mono",
  "icon_theme": {
    "mode": "dark",
    "light": "Catppuccin Frappé",
    "dark": "Catppuccin Frappé"
  },
  "ui_font_size": 14.5,
  "theme": {
    "mode": "dark",
    "light": "Ayu Light",
    "dark": "Gruvbox Dark Solid"
  },
  "tabs": { "file_icons": true },
  "vim": {
    "use_smartcase_find": false,
    "toggle_relative_line_numbers": true,
    "use_system_clipboard": "on_yank"
  },
  "git": {
    "inline_blame": {
      "enabled": false
    }
  },
  "diagnostics": {
    "inline": {
      "enabled": true
    }
  },
  "inlay_hints": {
    "enabled": true
  },
  "languages": {
    "TSX": {
      "inlay_hints": {
        "show_parameter_hints": true,
        "show_type_hints": false
      }
    },
    "TypeScript": {
      "inlay_hints": {
        "show_background": false,
        "show_type_hints": false,
        "show_value_hints": true,
        "enabled": true
      }
    },
    "C": {
      "format_on_save": "on"
      // does not work :(
      // "tab_size": 4,
    },
    "Python": {
      // "language_servers": [
      //     // Disable basedpyright and enable ty, and otherwise
      //     // use the default configuration.
      //     "ty",
      //     "!basedpyright",
      //     "...",
      // ],
    },
    "YAML": {
      "tab_size": 2,
      "hard_tabs": false
    },
    "JSON": {
      "tab_size": 4,
      "hard_tabs": false
    },
    "JSONC": {
      "tab_size": 4,
      "hard_tabs": false
    }
  }
}
